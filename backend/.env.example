# Comma-separated list of allowed frontend origins (plain string, not JSON).
AUTOSIGN_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Shared secret required on every API request (X-Access-Token header) once set.
# Leave empty for local development. ALWAYS set this to a long random value
# before deploying anywhere reachable from the public internet.
AUTOSIGN_ACCESS_TOKEN=
